<%- include('partials/header') %>
<div class="page-head">
  <div>
    <h1>Alerts</h1>
    <p class="subtitle"><%= alerts.length %> active alert<%= alerts.length === 1 ? '' : 's' %>, derived live from deadlines, spend pace, and reporting status</p>
  </div>
</div>

<% if (!alerts.length) { %>
  <div class="card empty">No active alerts. Every grant is within its deadlines and reporting is current. 🎉</div>
<% } else { %>
  <% [['critical','Critical'],['high','High'],['medium','Medium']].forEach(function (grp) {
       const list = groups[grp[0]]; if (!list.length) return; %>
    <section class="card" style="margin-bottom:16px;">
      <h2 class="sev-<%= grp[0] %>"><%= grp[1] %> <span class="badge muted"><%= list.length %></span></h2>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Grant</th><th>Type</th><th>Detail</th><th class="num nowrap">Deadline</th></tr></thead>
          <tbody>
            <% list.forEach(function (a) { %>
              <tr>
                <td><a class="row-link" href="/grants/<%= a.grant_id %>"><%= a.grant_number %></a><div class="small muted"><%= a.title %></div></td>
                <td class="nowrap"><%= a.kind %></td>
                <td><%= a.message %></td>
                <td class="num nowrap"><%= a.days != null ? (a.days < 0 ? Math.abs(a.days) + 'd overdue' : 'in ' + a.days + 'd') : '—' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </section>
  <% }); %>
<% } %>
<%- include('partials/footer') %>
