<%- include('partials/header') %>
<% const unspent = Math.max(0, grant.award_amount - grant.expended_amount);
   const unobligated = Math.max(0, grant.award_amount - grant.obligated_amount);
   const spentPct = grant.award_amount > 0 ? grant.expended_amount / grant.award_amount : 0; %>

<div class="page-head">
  <div>
    <h1 style="margin-bottom:2px;"><%= grant.grant_number %>
      <span class="badge <%= tierClass(grant.risk_tier) %>">Risk <%= grant.risk_score %> · <%= humanize(grant.risk_tier) %></span>
    </h1>
    <p class="subtitle"><%= grant.title %></p>
    <div>
      <span class="badge muted"><%= fundingLabel(grant.funding_source) %></span>
      <span class="badge muted"><%= humanize(grant.status) %></span>
      <span class="badge muted">Class: <%= humanize(grant.classification) %></span>
    </div>
  </div>
  <div class="toolbar no-print">
    <a class="btn secondary" href="/grants/<%= grant.id %>/packet">Compliance packet</a>
    <a class="btn ghost" href="/grants">← Grants</a>
  </div>
</div>

<% if (created) { %><div class="banner ok">Grant created and scored.</div><% } %>
<% if (saved) { %><div class="banner ok">Changes saved. The audit trail and risk score were updated.</div><% } %>
<% if (errorMsg) { %><div class="banner err"><%= errorMsg %></div><% } %>

<div class="detail-grid">
  <div class="stack">
    <!-- Overview -->
    <section class="card">
      <h2>Overview</h2>
      <dl class="kv">
        <dt>Grantor</dt><dd><%= grant.grantor || '—' %></dd>
        <dt>Program</dt><dd><%= grant.program || '—' %></dd>
        <dt>Subrecipient</dt><dd><%= grant.subrecipient || '—' %></dd>
        <dt>Department</dt><dd><%= grant.department || '—' %></dd>
        <dt>Category</dt><dd><%= grant.category || '—' %></dd>
        <dt>Owner</dt><dd><%= grant.assigned_to || '—' %></dd>
        <dt>Award date</dt><dd><%= fmtDate(grant.award_date) %></dd>
        <dt>Obligation deadline</dt><dd><%= fmtDate(grant.obligation_deadline) %> <span class="small muted"><%= grant.obligation_deadline ? relativeDays(grant.obligation_deadline) : '' %></span></dd>
        <dt>Expenditure deadline</dt><dd><%= fmtDate(grant.expenditure_deadline) %> <span class="small muted"><%= relativeDays(grant.expenditure_deadline) %></span></dd>
      </dl>
      <hr class="sep" />
      <dl class="kv">
        <dt>Award</dt><dd><%= fmtMoneyExact(grant.award_amount) %></dd>
        <dt>Obligated</dt><dd><%= fmtMoneyExact(grant.obligated_amount) %> · <span class="muted"><%= fmtMoney(unobligated) %> unobligated</span></dd>
        <dt>Expended</dt><dd><%= fmtMoneyExact(grant.expended_amount) %></dd>
        <dt>Unspent</dt><dd><strong><%= fmtMoneyExact(unspent) %></strong></dd>
        <dt>Spend progress</dt>
        <dd>
          <div class="meter" style="max-width:220px;"><span style="width:<%= Math.round(spentPct*100) %>%;"></span></div>
          <span class="small muted"><%= fmtPct(spentPct) %> spent</span>
        </dd>
      </dl>
      <% if (grant.review_notes) { %>
        <hr class="sep" />
        <h3>Review notes</h3>
        <p class="small"><%= grant.review_notes %></p>
        <p class="small muted">Last reviewed: <%= fmtDateTime(grant.last_reviewed_at) %></p>
      <% } %>
    </section>

    <!-- Edit -->
    <section class="card no-print">
      <details>
        <summary style="cursor:pointer; font-weight:700;">Edit grant &amp; record review</summary>
        <form method="post" action="/grants/<%= grant.id %>" style="margin-top:14px;">
          <div class="form-grid">
            <div class="field"><label>Status</label>
              <select name="status">
                <% enums.GRANT_STATUSES.forEach(function (s) { %><option value="<%= s %>" <%= grant.status===s?'selected':'' %>><%= humanize(s) %></option><% }); %>
              </select>
            </div>
            <div class="field"><label>Classification</label>
              <select name="classification">
                <% enums.CLASSIFICATIONS.forEach(function (s) { %><option value="<%= s %>" <%= grant.classification===s?'selected':'' %>><%= humanize(s) %></option><% }); %>
              </select>
            </div>
            <div class="field"><label>Owner</label><input name="assigned_to" value="<%= grant.assigned_to || '' %>" /></div>
            <div class="field"><label>Department</label><input name="department" value="<%= grant.department || '' %>" /></div>
            <div class="field"><label>Obligated amount</label><input name="obligated_amount" inputmode="decimal" value="<%= grant.obligated_amount %>" /></div>
            <div class="field"><label>Expended amount</label><input name="expended_amount" inputmode="decimal" value="<%= grant.expended_amount %>" /></div>
            <div class="field"><label>Obligation deadline</label><input name="obligation_deadline" type="date" value="<%= grant.obligation_deadline || '' %>" /></div>
            <div class="field"><label>Expenditure deadline</label><input name="expenditure_deadline" type="date" value="<%= grant.expenditure_deadline %>" /></div>
          </div>
          <div class="field"><label>Review notes</label><textarea name="review_notes" style="min-height:80px;"><%= grant.review_notes || '' %></textarea></div>
          <button class="btn" type="submit">Save changes</button>
        </form>
      </details>
    </section>

    <!-- Tasks -->
    <section class="card" id="tasks">
      <h2>Reporting obligations</h2>
      <% if (!tasks.length) { %>
        <p class="muted small">No reporting obligations tracked yet.</p>
      <% } else { %>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Obligation</th><th>Due</th><th>Status</th><th>Outcome</th><th class="no-print"></th></tr></thead>
            <tbody>
              <% tasks.forEach(function (t) {
                   const overdue = (t.status === 'open' || t.status === 'submitted') && daysTo(t.due_date) < 0; %>
                <tr>
                  <td><%= t.title %><div class="small muted"><%= humanize(t.type) %></div></td>
                  <td class="nowrap"><%= fmtDate(t.due_date) %>
                    <div class="small <%= overdue ? 'sev-critical' : 'muted' %>"><%= relativeDays(t.due_date) %></div>
                  </td>
                  <td><%= humanize(t.status) %></td>
                  <td><%= t.outcome ? humanize(t.outcome) + (t.turnaround_days != null ? ' · ' + t.turnaround_days + 'd' : '') : '—' %></td>
                  <td class="no-print">
                    <% if (t.status === 'open' || t.status === 'submitted') { %>
                      <form method="post" action="/grants/<%= grant.id %>/tasks/<%= t.id %>/complete" class="toolbar">
                        <select name="outcome" aria-label="Outcome">
                          <option value="">Auto (on-time/late)</option>
                          <% taskOutcomes.forEach(function (o) { %><option value="<%= o %>"><%= humanize(o) %></option><% }); %>
                        </select>
                        <button class="btn small" type="submit">Complete</button>
                      </form>
                    <% } %>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>

      <details class="no-print" style="margin-top:14px;">
        <summary style="cursor:pointer; font-weight:600;">+ Add reporting obligation</summary>
        <form method="post" action="/grants/<%= grant.id %>/tasks" style="margin-top:12px;">
          <div class="form-grid">
            <div class="field"><label>Type</label>
              <select name="type">
                <% enums.TASK_TYPES.forEach(function (s) { %><option value="<%= s %>"><%= humanize(s) %></option><% }); %>
              </select>
            </div>
            <div class="field"><label>Due date</label><input name="due_date" type="date" required /></div>
          </div>
          <div class="field"><label>Title</label><input name="title" required placeholder="e.g. Q3 2026 Project & Expenditure Report" /></div>
          <button class="btn" type="submit">Add obligation</button>
        </form>
      </details>
    </section>

    <!-- Audit trail -->
    <section class="card">
      <h2>Audit trail <span class="small muted">(immutable · <%= events.length %> events)</span></h2>
      <ul class="timeline">
        <% events.forEach(function (e) { %>
          <li>
            <div class="when"><%= fmtDateTime(e.at) %> · <%= e.actor %> · <span class="badge muted"><%= humanize(e.event_type) %></span> · <span class="muted"><%= e.source %></span></div>
            <div class="summary"><%= e.summary %></div>
            <% if (e.field && (e.old_value || e.new_value)) { %>
              <div class="small muted"><%= e.old_value || '—' %> → <%= e.new_value || '—' %></div>
            <% } %>
          </li>
        <% }); %>
      </ul>
    </section>
  </div>

  <!-- Risk panel -->
  <aside class="card">
    <h2>Risk assessment</h2>
    <div class="risk-dial">
      <div class="num" style="color:var(--tier-<%= risk.tier %>);"><%= risk.score %></div>
      <div class="out">/ 100 · <span class="badge <%= tierClass(risk.tier) %>"><%= humanize(risk.tier) %></span></div>
    </div>
    <p class="small muted" style="text-align:center;">Composite of five weighted factors, recomputed live.</p>
    <hr class="sep" />
    <% risk.factors.forEach(function (f) {
         const pct = f.weight ? Math.round(f.risk * 100) : 0;
         const tone = f.risk >= 0.66 ? 'critical' : f.risk >= 0.33 ? 'high' : 'low'; %>
      <div class="factor">
        <div class="top"><span><%= f.label %></span><span class="muted"><%= Math.round(f.points) %> / <%= f.weight %></span></div>
        <div class="bar"><span style="width:<%= pct %>%; background:var(--tier-<%= tone %>);"></span></div>
        <div class="small muted"><%= f.detail %></div>
      </div>
    <% }); %>
  </aside>
</div>
<%- include('partials/footer') %>
