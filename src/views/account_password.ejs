<%- include('partials/header') %>
<div class="page-head">
  <div>
    <h1>Change password</h1>
    <p class="subtitle">
      <% if (forced) { %>
        You're using a temporary password. Please set your own to continue.
      <% } else { %>
        Update the password for <%= currentUser.email %>.
      <% } %>
    </p>
  </div>
</div>

<% if (forced) { %><div class="banner info">A password change is required before you can use the app.</div><% } %>
<% if (error) { %><div class="banner err"><%= error %></div><% } %>

<section class="card" style="max-width:480px;">
  <form method="post" action="/account/password">
    <%- include('partials/csrf') %>
    <div class="field">
      <label for="current_password">Current password</label>
      <input id="current_password" name="current_password" type="password" autocomplete="current-password" required />
    </div>
    <div class="field">
      <label for="new_password">New password <span class="hint">(at least <%= minLength %> characters, mix letters with a number or symbol)</span></label>
      <input id="new_password" name="new_password" type="password" autocomplete="new-password" required />
    </div>
    <div class="field">
      <label for="confirm_password">Confirm new password</label>
      <input id="confirm_password" name="confirm_password" type="password" autocomplete="new-password" required />
    </div>
    <button class="btn" type="submit">Update password</button>
  </form>
</section>
<%- include('partials/footer') %>
