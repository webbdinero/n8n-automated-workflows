<%- include('partials/header') %>
<div class="page-head">
  <div>
    <h1>Admin &amp; Settings</h1>
    <p class="subtitle">Subscription, data operations, and peer benchmarks</p>
  </div>
</div>

<% if (locals.query && query.recomputed !== undefined) { %>
  <div class="banner ok">Recomputed risk scores. <%= query.recomputed %> grant(s) changed tier or score.</div>
<% } %>
<% if (locals.query && query.subscription !== undefined) { %>
  <div class="banner ok">Subscription settings updated.</div>
<% } %>
<% if (locals.query && query.token_rotated !== undefined) { %>
  <div class="banner ok">API token rotated. Update any n8n / automation credentials.</div>
<% } %>

<div class="grid cols-2">
  <section class="card" id="subscription">
    <h2>Subscription</h2>
    <dl class="kv">
      <dt>Plan</dt><dd><span class="badge muted"><%= planLabel %></span></dd>
      <dt>Status</dt><dd><%= humanize(org.subscription_status) %></dd>
      <dt>Trial ends</dt><dd><%= org.trial_ends_at ? fmtDate(org.trial_ends_at) : '—' %></dd>
      <dt>Seats included</dt><dd><%= entitlements.seatsIncluded %></dd>
      <dt>Grant limit</dt><dd><%= entitlements.maxGrants == null ? 'Unlimited' : entitlements.maxGrants %> <span class="small muted">(<%= counts.grants %> used)</span></dd>
    </dl>
    <hr class="sep" />
    <h3>Included features</h3>
    <p>
      <span class="badge <%= entitlements.benchmarks ? 'tier-low' : 'muted' %>">Benchmarks <%= entitlements.benchmarks ? '✓' : '✗' %></span>
      <span class="badge <%= entitlements.premiumPackets ? 'tier-low' : 'muted' %>">Premium packets <%= entitlements.premiumPackets ? '✓' : '✗' %></span>
      <span class="badge <%= entitlements.jsonExport ? 'tier-low' : 'muted' %>">JSON export <%= entitlements.jsonExport ? '✓' : '✗' %></span>
      <span class="badge <%= entitlements.apiAccess ? 'tier-low' : 'muted' %>">API access <%= entitlements.apiAccess ? '✓' : '✗' %></span>
    </p>
    <hr class="sep" />
    <% if (!currentUser || currentUser.role !== 'admin') { %>
      <p class="small muted">Only administrators can change the plan or billing status.</p>
    <% } else { %>
    <form method="post" action="/admin/subscription">
      <div class="form-grid">
        <div class="field">
          <label for="plan">Plan</label>
          <select id="plan" name="plan">
            <% enums.PLANS.forEach(function (p) { %>
              <option value="<%= p %>" <%= org.plan === p ? 'selected' : '' %>><%= humanize(p) %></option>
            <% }); %>
          </select>
        </div>
        <div class="field">
          <label for="subscription_status">Status</label>
          <select id="subscription_status" name="subscription_status">
            <% enums.SUBSCRIPTION_STATUSES.forEach(function (s) { %>
              <option value="<%= s %>" <%= org.subscription_status === s ? 'selected' : '' %>><%= humanize(s) %></option>
            <% }); %>
          </select>
        </div>
      </div>
      <div class="field">
        <label style="font-weight:400;">
          <input type="checkbox" name="data_sharing_opt_in" style="width:auto; margin-right:6px;" <%= org.data_sharing_opt_in ? 'checked' : '' %> />
          Contribute anonymized data to peer benchmarks (required to appear in others' peer pool)
        </label>
      </div>
      <div class="field">
        <label for="reason">Reason / note <span class="hint">(recorded in the audit log)</span></label>
        <input id="reason" name="reason" placeholder="e.g. Converted from trial after pilot kickoff" />
      </div>
      <button class="btn" type="submit">Save subscription</button>
    </form>
    <% } %>
  </section>

  <section class="card">
    <h2>Usage this account <span class="small muted">(metered — billing basis)</span></h2>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Metered action</th><th class="num">Count</th></tr></thead>
        <tbody>
          <% [['packet_generated','Compliance packets generated'],['export_csv','CSV exports'],['export_json','JSON exports'],['import','Grants imported']].forEach(function (u) { %>
            <tr><td><%= u[1] %></td><td class="num"><%= usage[u[0]] || 0 %></td></tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <hr class="sep" />
    <h3>Data operations</h3>
    <form method="post" action="/admin/recompute" style="margin-bottom:12px;">
      <button class="btn" type="submit">Recompute all risk scores</button>
    </form>
    <div class="toolbar">
      <a class="btn ghost" href="/exports/grants.csv">Export portfolio CSV</a>
      <a class="btn ghost" href="/exports/grants.json">Export full JSON<%= entitlements.jsonExport ? '' : ' 🔒' %></a>
    </div>
  </section>
</div>

<section class="card" style="margin-top:16px;">
  <h2>API access &amp; users</h2>
  <p class="small muted">The JSON API and automation (n8n) authenticate with this per-org token. Send it as <code>Authorization: Bearer &lt;token&gt;</code> or <code>x-api-key</code>. Treat it like a password.</p>
  <div class="field">
    <label>API token</label>
    <input type="text" readonly value="<%= apiToken || '(none)' %>" onclick="this.select()" style="font-family:ui-monospace,monospace;" />
  </div>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <form method="post" action="/admin/rotate-token" data-confirm="Rotate the API token? Existing integrations will stop working until updated.">
      <button class="btn ghost small" type="submit">Rotate token</button>
    </form>
  <% } else { %>
    <p class="small muted">Only administrators can rotate the token.</p>
  <% } %>
  <hr class="sep" />
  <h3>Operators</h3>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Name</th><th>Email</th><th>Role</th><th class="nowrap">Last sign-in</th></tr></thead>
      <tbody>
        <% users.forEach(function (u) { %>
          <tr><td><%= u.name %></td><td><%= u.email %></td><td><%= humanize(u.role) %></td><td class="small nowrap"><%= u.last_login_at ? fmtDateTime(u.last_login_at) : '—' %></td></tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</section>

<section class="card" style="margin-top:16px;">
  <h2>Subscription history <span class="small muted">(immutable audit log)</span></h2>
  <% if (!subscriptionHistory || !subscriptionHistory.length) { %>
    <p class="muted small">No subscription changes recorded yet.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead><tr><th class="nowrap">When</th><th>Actor</th><th>Field</th><th>Change</th><th>Reason</th></tr></thead>
        <tbody>
          <% subscriptionHistory.forEach(function (e) { %>
            <tr>
              <td class="nowrap small"><%= fmtDateTime(e.at) %></td>
              <td><%= e.actor %></td>
              <td><%= humanize(e.field) %></td>
              <td><%= e.old_value || '—' %> → <%= e.new_value || '—' %></td>
              <td class="small"><%= e.reason || '—' %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="card" style="margin-top:16px;">
  <h2>Peer benchmarks <span class="small muted"><%= entitlements.benchmarks ? '(anonymized · ' + (benchmark ? benchmark.peerOrgCount : 0) + ' opted-in peer org(s))' : '(premium)' %></span></h2>
  <% if (!entitlements.benchmarks || !benchmark) { %>
    <p class="muted">Peer benchmarking is a premium feature. It compares this organization to the pooled, anonymized peer set — the seed of a licensable benchmarking product.</p>
    <a class="btn" href="#subscription">Upgrade to unlock benchmarks</a>
  <% } else { %>
    <p class="small muted">Only organizations that opted in to data sharing are pooled. This is the intelligence layer and long-term data moat.</p>
    <div class="table-wrap">
      <table>
        <thead><tr><th>Metric</th><th class="num"><%= org.name %></th><th class="num">Peer pool</th></tr></thead>
        <tbody>
          <tr><td>Burn rate (spent / award)</td><td class="num"><%= fmtPct(benchmark.org.burnRatePct) %></td><td class="num"><%= fmtPct(benchmark.peer.burnRatePct) %></td></tr>
          <tr><td>Unspent share</td><td class="num"><%= fmtPct(benchmark.org.unspentPct) %></td><td class="num"><%= fmtPct(benchmark.peer.unspentPct) %></td></tr>
          <tr><td>On-time reporting rate</td><td class="num"><%= fmtPct(benchmark.org.onTimeReportPct) %></td><td class="num"><%= fmtPct(benchmark.peer.onTimeReportPct) %></td></tr>
          <tr><td>Avg reporting turnaround</td>
            <td class="num"><%= benchmark.org.avgTurnaroundDays != null ? benchmark.org.avgTurnaroundDays.toFixed(1) + ' d' : '—' %></td>
            <td class="num"><%= benchmark.peer.avgTurnaroundDays != null ? benchmark.peer.avgTurnaroundDays.toFixed(1) + ' d' : '—' %></td>
          </tr>
          <tr><td>Share of active grants at risk</td><td class="num"><%= fmtPct(benchmark.org.atRiskPct) %></td><td class="num"><%= fmtPct(benchmark.peer.atRiskPct) %></td></tr>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="card" style="margin-top:16px;">
  <h2>Organization</h2>
  <dl class="kv">
    <dt>Name</dt><dd><%= org.name %></dd>
    <dt>Slug</dt><dd><code><%= org.slug %></code></dd>
    <dt>Type</dt><dd><%= humanize(org.type) %></dd>
    <dt>State / region</dt><dd><%= org.state || '—' %><%= org.region ? ' · ' + org.region : '' %></dd>
    <dt>Population</dt><dd><%= org.population ? org.population.toLocaleString() : '—' %></dd>
    <dt>Grants / obligations / events</dt><dd><%= counts.grants %> / <%= counts.tasks %> / <%= counts.events %></dd>
  </dl>
</section>

<section class="card" style="margin-top:16px;">
  <h2>Proprietary data captured (the moat)</h2>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Field / structure</th><th>Why it's proprietary &amp; defensible</th></tr></thead>
      <tbody>
        <tr><td><strong>Immutable audit trail</strong></td><td>Every change is appended, never overwritten — a longitudinal record no competitor can reconstruct and the basis of switching cost.</td></tr>
        <tr><td><strong>Reporting outcomes &amp; turnaround</strong></td><td>On-time / late / missed and days-to-close per obligation — measurable operational performance data.</td></tr>
        <tr><td><strong>Reviewer classification &amp; notes</strong></td><td>Human compliance judgment that encodes expertise and trains future automation.</td></tr>
        <tr><td><strong>Metered usage records</strong></td><td>Packet/report and export activity — the basis for usage-based and premium-report billing.</td></tr>
        <tr><td><strong>Canonical cross-org schema + opt-in</strong></td><td>Uniform structure plus data-sharing consent makes anonymized benchmarking and data-licensing products possible.</td></tr>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
