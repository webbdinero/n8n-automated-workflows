# GrantGuard configuration
# Copy to .env and adjust as needed. Sensible defaults are baked in, so
# GrantGuard runs with no .env at all.

# HTTP port
PORT=3000

# SQLite database file (relative to project root). Swap the repository layer
# for Postgres later without touching routes/services.
DATABASE_PATH=data/grantguard.db

# Default organization slug used when a request has no explicit org context.
# In the MVP this is the single pilot tenant.
DEFAULT_ORG_SLUG=demo-borough

# Node environment
NODE_ENV=development

# --- Authentication ---
# Secret used to sign session cookies. Set a long random value in production so
# sessions survive restarts (unset = ephemeral per-boot secret, dev only).
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Bootstrap admin for the default org on first boot (only used if no user exists).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Password for the seeded pilot admin (npm run seed). Defaults to grantguard-pilot.
SEED_ADMIN_PASSWORD=

# Minimum length for user-chosen passwords (first-login change / reset).
PASSWORD_MIN_LENGTH=10

# Multi-instance seam (NOT implemented yet). When set, the login rate limiter
# and sessions should be backed by Redis. See docs/PRODUCTION_AUTH.md.
REDIS_URL=
