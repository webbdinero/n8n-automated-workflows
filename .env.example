# GrantGuard configuration
# Copy to .env and adjust as needed. Sensible defaults are baked in, so
# GrantGuard runs with no .env at all.

# HTTP port
PORT=3000

# SQLite database file (relative to project root). Swap the repository layer
# for Postgres later without touching routes/services.
DATABASE_PATH=data/grantguard.db

# Default organization slug used when a request has no explicit org context.
# In the MVP this is the single pilot tenant.
DEFAULT_ORG_SLUG=demo-borough

# Node environment
NODE_ENV=development
