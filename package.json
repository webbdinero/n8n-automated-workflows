{
  "name": "grantguard",
  "version": "0.1.0",
  "private": true,
  "description": "GrantGuard — compliance monitoring & audit-packet automation for public-sector grants (ARPA/SLFRF, CDBG, state & federal).",
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 tsx watch src/index.ts",
    "start": "NODE_NO_WARNINGS=1 tsx src/index.ts",
    "seed": "NODE_NO_WARNINGS=1 tsx src/db/seed.ts",
    "reset": "rm -f data/grantguard.db && npm run seed",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
